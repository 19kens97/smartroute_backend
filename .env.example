DEBUG=True
SECRET_KEY=change-me-with-at-least-32-characters
ALLOWED_HOSTS=*
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=
USE_REDIS=False
USE_CELERY=False
REDIS_URL=redis://127.0.0.1:6379/1
CACHE_KEY_PREFIX=smartroute
CACHE_TIMEOUT_SECONDS=300
# WebSocket events and Django cache use Redis when USE_REDIS=True. Keep False only for isolated local development/tests.
CELERY_BROKER_URL=redis://127.0.0.1:6379/2
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/3
POSTGRES_DB=smartroute
POSTGRES_USER=smartroute
POSTGRES_PASSWORD=smartroute
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.0-flash
GEMINI_LOG_RESPONSE=False
GEMINI_LOG_RAW_RESPONSE=False
ENABLE_RECOGNIZE_ENDPOINT=False
API_RESPONSE_LOGGING_ENABLED=True
API_RESPONSE_LOGGING_PATH_PREFIX=/api/
API_RESPONSE_LOGGING_MAX_CHARS=4000
API_RESPONSE_LOGGING_INCLUDE_BODY=True
# Media storage
MEDIA_STORAGE_BACKEND=django.core.files.storage.FileSystemStorage
MEDIA_ROOT=
MEDIA_URL=/media/
MEDIA_BASE_URL=
PRIVATE_MEDIA_ENABLED=True
PRIVATE_SIGNATURE_ROOT=
PRIVATE_ALERT_EVIDENCE_ROOT=
MAX_IMAGE_SIZE_MB=5
MAX_VIDEO_SIZE_MB=35
MAX_AUDIO_SIZE_MB=10
MAX_DOCUMENT_SIZE_MB=5
# Future S3-compatible storage values
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_S3_ENDPOINT_URL=
